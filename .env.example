# LLM Configuration for AI Twin (Optional API configs)
# Used specifically in src/app/api/chat/route.ts for the AI twin integration.

# The LLM API Key (e.g. from Nvidia integrations or OpenAI)
LLM_API_KEY=""

# The base URL of the LLM endpoint if not using default Nvidia integration
# e.g., https://api.openai.com/v1/chat/completions
LLM_BASE_URL="https://integrate.api.nvidia.com/v1/chat/completions"

# Override default model
# AI_MODEL="mistralai/mistral-small-3.1-24b-instruct-2503"
