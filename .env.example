# The base URL of the LLM endpoint if not using default Nvidia integration
# e.g., https://api.openai.com/v1/chat/completions
LLM_BASE_URL="https://integrate.api.nvidia.com/v1/chat/completions"

# Override default model
# AI_MODEL="openai/gpt-oss-20b"

# Resend contact form delivery
# Verify your sending domain in Resend first, then use an address on that domain.
RESEND_API_KEY="re_your_resend_api_key"
